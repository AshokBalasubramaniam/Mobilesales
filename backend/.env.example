# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/mobilesales

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Cookies
REFRESH_COOKIE_NAME=msm_refresh_token

# Redis (optional — caching disabled gracefully if unset)
REDIS_URL=

# AWS S3 (optional — falls back to local disk storage under /uploads if unset)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
CLOUDFRONT_DOMAIN=

# Razorpay (optional — falls back to a mock payment adapter if unset)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google OAuth (optional — Google login disabled if unset)
GOOGLE_CLIENT_ID=

# Email / SMTP (optional — falls back to console-logged mock emails if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Mobile Sales <no-reply@mobilesales.local>"

# SMS / OTP provider (optional — falls back to console-logged mock OTPs if unset)
SMS_API_KEY=
SMS_SENDER_ID=

# Admin bootstrap (used by seed script)
ADMIN_EMAIL=admin@mobilesales.local
ADMIN_PASSWORD=Admin@12345

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
